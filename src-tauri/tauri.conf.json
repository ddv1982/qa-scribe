{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qa-scribe",
  "version": "0.4.1",
  "identifier": "com.qa-scribe.app",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "beforeBuildCommand": "cd frontend && bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "qa-scribe",
        "width": 1280,
        "height": 860,
        "minWidth": 640,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"]
  }
}
