{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QA Scribe",
  "version": "0.6.3",
  "identifier": "io.github.ddv1982.qa-scribe",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "beforeBuildCommand": "scripts/build_frontend_for_tauri.sh",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "QA Scribe",
        "width": 1280,
        "height": 860,
        "minWidth": 640,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icons/16x16.png",
      "../build/icons/32x32.png",
      "../build/icons/48x48.png",
      "../build/icons/64x64.png",
      "../build/icons/128x128.png",
      "../build/icons/256x256.png",
      "../build/icons/512x512.png",
      "../build/icons/1024x1024.png",
      "../build/macos/AppIcon.icns"
    ],
    "shortDescription": "Local-first desktop testing notepad",
    "longDescription": "QA Scribe is a local-first desktop testing notepad for turning testing sessions, evidence, findings, and notes into structured testware.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "Productivity",
    "linux": {
      "deb": {
        "depends": [],
        "files": {
          "/usr/share/doc/qa-scribe/copyright": "../build/linux/debian/copyright",
          "/usr/share/metainfo/io.github.ddv1982.qa-scribe.metainfo.xml": "../build/linux/io.github.ddv1982.qa-scribe.metainfo.xml"
        }
      },
      "rpm": {
        "depends": [],
        "files": {
          "/usr/share/licenses/qa-scribe/LICENSE": "../LICENSE",
          "/usr/share/metainfo/io.github.ddv1982.qa-scribe.metainfo.xml": "../build/linux/io.github.ddv1982.qa-scribe.metainfo.xml"
        }
      }
    },
    "macOS": {
      "entitlements": "../build/entitlements.mac.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null
    }
  },
  "mainBinaryName": "qa-scribe"
}
