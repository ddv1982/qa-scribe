{
  "include": ["electrobun.config.ts", "src/bun/**/*.ts", "src/main/**/*.ts", "src/shared/**/*.ts", "drizzle.config.ts"],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "types": ["node", "bun", "vitest"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  }
}
